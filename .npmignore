# Publishing manifest. The `files` whitelist in package.json is the source of
# truth; this file documents intent and protects against accidentally
# including dev-only artifacts even if `files` is later edited.
#
# Always published (cannot be excluded):
#   - package.json
#   - README, LICENSE, CHANGELOG
#   - entry points listed in `files` — currently `index.ts` and `src/**/*.ts`
#     (orchestrator + the three core modules under src/core/)

# Dev / build
tsconfig.json
.gitignore
.npmignore

# Agent / scratch dirs (local-only, not committed)
.agents/
.codex/
.pi/

# Editor / OS
.DS_Store
*.log
